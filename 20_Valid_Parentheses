class Solution:

    def isValid(self, s: str) -> bool:
        stack = []

        opening = ["(", "[", "{"]
        closing = [")", "]", "}"]

        parenthesis_dict = {
            "(": ")",
            "[": "]",
            "{": "}"
        }

        for parenthesis in s:
            if len(stack) != 0:
                top_element = stack[-1]

            if parenthesis in opening:
                stack.append(parenthesis)

            if parenthesis in closing:
                if len(stack) == 0:
                    return False

                if parenthesis == parenthesis_dict[top_element]:
                    stack.pop()
                else:
                    return False
        
        if len(stack) != 0:
            return False
        else:
            return True


if __name__ == '__main__':
    s = Solution()
    assert s.isValid("()") == True
    assert s.isValid("()[]{}") == True
    assert s.isValid("(]") == False
    assert s.isValid("([])") == True
    assert s.isValid("([)])") == False